{
  "expo": {
    "name": "SojournX",
    "slug": "sojournx",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./src/assets/icon-square.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/hero.png",
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sojournx.app"
    },
    "android": {
      "package": "com.sojournx.app",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon-square.png",
        "backgroundColor": "#050505"
      }
    },
    "web": {
      "bundler": "metro",
      "backgroundColor": "#050505"
    },
    "extra": {
      "eas": {
        "projectId": "sojournx-beta"
      }
    }
  }
}