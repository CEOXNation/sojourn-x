{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "jsx": "react-native",
    "moduleResolution": "node",
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "./**/*",
    "../BetaApp.tsx",
    "../App.tsx",
    "../src/**/*"
  ],
  "exclude": [
    "node_modules",
    "../node_modules"
  ]
}
